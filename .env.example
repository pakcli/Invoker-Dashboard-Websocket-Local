# Path to the local directory where portfolio markdown files are stored
# For example: PORTFOLIO_WATCH_DIR=D:/my-portfolio-data
# If left empty, it defaults to the relative './data' folder inside the project
PORTFOLIO_WATCH_DIR=

# Port on which the Flask server will listen
PORT=5000

# File change watcher debounce timing in seconds
DEBOUNCE_SECONDS=1.5
